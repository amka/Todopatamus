using Gtk 4.0;
using Adw 1;

template $TodopatamusWindow : Adw.ApplicationWindow {
  default-width: 1000;
  default-height: 800;
  title: _("Todopatamus");

  Adw.Leaflet main_leaflet {
    vexpand: true;
    can-navigate-back: true;
    can-unfold: false;

    Adw.LeafletPage projects_leaflet {
      name: "projects_page";

      child: $ProjectsPage projects_page {};
    }
  }
}
